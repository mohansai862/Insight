<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Define log pattern with timestamp, level, class, line number, and message -->
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50}:%line - %msg%n"/>
    <property name="ERROR_LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50}:%line - %msg%n%ex"/>
    
    <!-- Development Profile -->
    <springProfile name="!prod">
        <!-- Console Appender for Development -->
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>
        
        <!-- File Appender for Development (optional) -->
        <appender name="DEV_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/crm-dev.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>logs/crm-dev.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>7</maxHistory>
                <totalSizeCap>500MB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>
        
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="DEV_FILE" />
        </root>
        
        <!-- Reduce framework noise in development -->
        <logger name="org.springframework" level="WARN"/>
        <logger name="org.hibernate" level="WARN"/>
        <logger name="com.zaxxer.hikari" level="WARN"/>
        <logger name="org.apache.catalina" level="WARN"/>
        <logger name="org.apache.tomcat" level="WARN"/>
        <logger name="org.springframework.web" level="WARN"/>
        
        <!-- Application logs at DEBUG level in development -->
        <logger name="com.techtammina.crm" level="DEBUG"/>
    </springProfile>

    <!-- Production Profile -->
    <springProfile name="prod">
        <!-- Main Application Log File -->
        <appender name="APP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/crm-application.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>logs/archived/crm-application.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
                <maxFileSize>100MB</maxFileSize>
                <maxHistory>60</maxHistory>
                <totalSizeCap>5GB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>
        
        <!-- Error Log File (ERROR and WARN only) -->
        <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/crm-errors.log</file>
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>WARN</level>
            </filter>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>logs/archived/crm-errors.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>90</maxHistory>
                <totalSizeCap>2GB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${ERROR_LOG_PATTERN}</pattern>
            </encoder>
        </appender>
        
        <!-- Security Log File -->
        <appender name="SECURITY_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/crm-security.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>logs/archived/crm-security.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>90</maxHistory>
                <totalSizeCap>1GB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>
        
        <!-- Business Operations Log File -->
        <appender name="BUSINESS_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/crm-business.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>logs/archived/crm-business.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
                <maxFileSize>100MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>3GB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>
        
        <root level="INFO">
            <appender-ref ref="APP_FILE" />
            <appender-ref ref="ERROR_FILE" />
        </root>
        
        <!-- Framework logging in production -->
        <logger name="org.springframework" level="WARN"/>
        <logger name="org.hibernate" level="WARN"/>
        <logger name="com.zaxxer.hikari" level="WARN"/>
        <logger name="org.apache.catalina" level="WARN"/>
        <logger name="org.apache.tomcat" level="WARN"/>
        <logger name="org.springframework.web" level="WARN"/>
        <logger name="org.springframework.security" level="WARN"/>
        
        <!-- Application logging -->
        <logger name="com.techtammina.crm" level="INFO" additivity="false">
            <appender-ref ref="APP_FILE" />
            <appender-ref ref="ERROR_FILE" />
            <appender-ref ref="BUSINESS_FILE" />
        </logger>
        
        <!-- Security-specific logging -->
        <logger name="com.techtammina.crm.service.AuthService" level="INFO" additivity="false">
            <appender-ref ref="SECURITY_FILE" />
            <appender-ref ref="ERROR_FILE" />
        </logger>
        
        <logger name="com.techtammina.crm.config.JwtAuthenticationFilter" level="INFO" additivity="false">
            <appender-ref ref="SECURITY_FILE" />
            <appender-ref ref="ERROR_FILE" />
        </logger>
        
        <!-- Performance logging -->
        <logger name="com.techtammina.crm.util.PerformanceLogger" level="INFO" additivity="false">
            <appender-ref ref="APP_FILE" />
            <appender-ref ref="ERROR_FILE" />
        </logger>
        
        <logger name="com.techtammina.crm.config.RequestLoggingInterceptor" level="INFO" additivity="false">
            <appender-ref ref="APP_FILE" />
            <appender-ref ref="ERROR_FILE" />
        </logger>
        
        <!-- Business operations logging -->
        <logger name="com.techtammina.crm.service.LeadService" level="INFO" additivity="false">
            <appender-ref ref="BUSINESS_FILE" />
            <appender-ref ref="ERROR_FILE" />
        </logger>
        
        <logger name="com.techtammina.crm.service.DealService" level="INFO" additivity="false">
            <appender-ref ref="BUSINESS_FILE" />
            <appender-ref ref="ERROR_FILE" />
        </logger>
        
        <logger name="com.techtammina.crm.service.EmailService" level="INFO" additivity="false">
            <appender-ref ref="BUSINESS_FILE" />
            <appender-ref ref="ERROR_FILE" />
        </logger>
    </springProfile>
</configuration>